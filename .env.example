# Copy this file to .env and fill in values. Do NOT commit .env.

# --- Shared Docker network ---------------------------------------------------
# The name of the existing Docker network where Traefik AND MongoDB already
# live. Inspect with `docker network ls`. Common: "app-net", "traefik_proxy".
SHARED_NETWORK=app-net

# Public hostname that Traefik routes to this service.
SERVER_HOST=claude-switch.dns.nom.es

# Traefik certResolver name configured in your traefik.yml (commonly "le",
# "letsencrypt", "myresolver", ...). Inspect your Traefik command-line:
#   docker inspect traefik --format '{{json .Args}}' | grep certResolvers
TRAEFIK_CERT_RESOLVER=le

# --- Mongo connection --------------------------------------------------------
# When running in Docker on the shared network, this is just the container
# name. Replace `mongodb` with the actual Mongo container name on your host.
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=claude_switch

# --- Public base URL ---------------------------------------------------------
# Must match the SERVER_HOST above. OAuth callbacks are derived from this.
# If you change the host, update both places AND update the OAuth app
# settings on github.com / console.cloud.google.com.
SERVER_BASE_URL=https://claude-switch.dns.nom.es

# --- OAuth credentials -------------------------------------------------------
# Register OAuth apps and paste the client ID + secret here.
#
# GitHub:  https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL: https://claude-switch.dns.nom.es/auth/github/callback
#
# Google:  https://console.cloud.google.com/apis/credentials
#   Application type: Web application
#   Authorized redirect URI:    https://claude-switch.dns.nom.es/auth/google/callback
#
# Either provider can be left empty to disable that login button. At least
# one must be configured; otherwise users cannot sign in.
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- Session signing key -----------------------------------------------------
# Used to HMAC-sign browser session cookies and CSRF tokens. Rotate by
# replacing this value (all logged-in users will be signed out).
# Generate with:  openssl rand -base64 48
SESSION_SECRET=

# --- Misc --------------------------------------------------------------------
LOG_LEVEL=info
